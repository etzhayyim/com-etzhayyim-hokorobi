{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:hokorobi",
  "type": "Actor",
  "name": "hokorobi",
  "glyph": "綻び",
  "purpose": "World systemic finance-risk observatory — weaves financial institutions / risk-sources / bearers (insurance + banking-lending + pensions) into the kotoba Datom log; surfaces systemic-risk concentration vs resilience routed to RESILIENCE; observation-only, never-trades, non-adjudicating.",
  "status": "R0-design-only",
  "tier": "B",
  "adr": "2606073400",
  "dependsOnAdr": ["2606073000", "2606073200", "2606032000", "2605302300", "2606022000", "2605301600", "2605312345", "2605215000"],
  "schema": ["00-contracts/schemas/finrisk-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.py emits canonical EAVT",
    "largeAssets": "DataLad → IPFS (80-data/finrisk) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000)",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy"
  },
  "integrates": ["actor:kanjo", "actor:kanae", "actor:kabuto", "actor:danjo", "actor:tsumugi", "actor:mitooshi"],
  "lineage": "risk-observation sibling of the disclosure/accountability lineage (kanjo/kanae/kabuto/danjo); finance-risk scope; OBSERVATION ONLY (finance production is Charter-excluded)",
  "cells": [
    {
      "id": "cell:hokorobi.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-finrisk-graph.kotoba.edn",
      "output": ["out/systemic-risk-report.md"],
      "pipeline": "load-edn → edge-primary integral (Σ incident inbound risk-load × disclosed systemic-importance weight) → systemic-risk-concentration + resilience-buffer + risk-source-concentration, aggregate-first",
      "doc": "edge-primary systemic-risk vs resilience; resilience map, never a panic/trading signal"
    },
    {
      "id": "cell:hokorobi.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-finrisk-graph.kotoba.edn",
      "output": ["out/finrisk-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (durable) + derived readouts flagged :bond/is-transient (computed on read, N1/G2)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:hokorobi.coverage",
      "method": "methods/coverage_report.py",
      "input": "data/seed-finrisk-graph.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "denominator (FSB G-SIB/IAIS/all-banks) + sector + sii-tier + risk-kind + bearer-kind → gap map",
      "doc": "honest coverage (all-institutions ~0 by design); names thin/missing buckets per wave (G5)"
    }
  ],
  "gates": {
    "G1": "RESILIENCE map, NEVER a panic / bank-run trigger, NEVER a trading / short / market-moving signal, NEVER a per-institution solvency verdict — it NEVER trades; aggregate-first; the 取-holder is the risk-source, the bearer is the public, the routing is resilience",
    "G2": "edge-primary (N1) — risk lives only on :en/risk-load; node systemic-risk is the integral computed on read; no :hokorobi/solvency-of-bank",
    "G3": "non-adjudicating (N3) — systemic-importance designations are DISCLOSED facts, never hokorobi verdicts; no investment advice / forecast",
    "G4": "public venue — open-source + on-chain + 1 SBT = 1 vote; never a private/covert registry or paid terminal",
    "G5": "sourcing honesty — every record :authoritative | :representative; risk-load values are representative severities, not measured solvency; no fabricated coverage",
    "G6": "Murakumo-only narration (ADR-2605215000)",
    "G7": "outward-gated — live ingest (FSB/IAIS/regulator disclosures) requires Council + operator DID; R0 = analyzer + schema + seed only",
    "G8": "observation-only — finance PRODUCTION (insurance/banking/lending) is Charter-excluded; hokorobi only observes"
  }
}
